# ==================== STRIPE ====================
# Stripe API Keys (LIVE MODE ONLY IN PRODUCTION)
# Find at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Stripe Price IDs (LIVE)
# Find at: https://dashboard.stripe.com/prices
NEXT_PUBLIC_STRIPE_PRICE_ONE_TIME=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_SUBSCRIPTION=price_xxxxxxxxxxxxx

# ==================== RESEND ====================
# Resend API Key (email service)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ==================== DEPLOYMENT ====================
# Production URL (Railway will auto-set this)
NEXT_PUBLIC_URL=https://your-domain.up.railway.app

# ==================== NODE ====================
# Environment
NODE_ENV=production

# ==================== OPTIONAL ====================
# Optional: Database connection (for future dashboard)
# DATABASE_URL=postgresql://user:password@host/dbname
